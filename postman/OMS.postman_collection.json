{
  "info": {
    "name": "QuickMart - Online Product Order Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@quickmart.com\",\n  \"password\": \"admin123\"\n}"
        }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Customer\",\n  \"email\": \"new@quickmart.com\",\n  \"password\": \"pass123\",\n  \"phone\": \"7777777777\"\n}"
        }
      }
    },
    {
      "name": "Products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/products?search=speaker"
      }
    },
    {
      "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/categories",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Accessories\",\n  \"description\": \"Useful add-ons\"\n}"
        }
      }
    },
    {
      "name": "Book Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": 1,\n  \"deliveryAddress\": \"MG Road, Bhubaneswar\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/orders/1/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
        }
      }
    },
    {
      "name": "Reports",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/reports/sales?from=2026-07-01&to=2026-07-31"
      }
    },
    {
      "name": "Raise Issue",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/issues",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": 1,\n  \"subject\": \"Delivery question\",\n  \"message\": \"When will my order arrive?\"\n}"
        }
      }
    }
  ]
}
